# Agefine Cosmetics — environment variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.

# Canonical production origin (no trailing slash), e.g. https://agefine.co.ke
# Used for metadataBase, canonical URLs, sitemap, robots, Open Graph.
# Falls back to the Vercel URL, then a placeholder, if unset.
NEXT_PUBLIC_SITE_URL=

# Supabase project (get from https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-side only — never expose to the browser; used by scripts/create-admin.mjs

# M-Pesa Buy Goods till number (provided by client)
NEXT_PUBLIC_TILL_NUMBER=000000

# Team invites are emailed by Supabase's built-in mailer (no custom domain
# needed for low volume). In the Supabase dashboard add your accept-invite URLs
# to Auth → URL Configuration → Redirect URLs, e.g.
#   http://localhost:3000/admin/accept-invite  and  <prod>/admin/accept-invite
# For higher volume / branded mail, configure custom SMTP under Auth → Emails.

# WhatsApp business number in international format, no + (e.g. 2547XXXXXXXX)
NEXT_PUBLIC_WHATSAPP=2547XXXXXXXX

# Groq API key (free tier) — powers "Generate with AI" in the service editor.
# Get one at https://console.groq.com/keys. Server-side only.
# Optionally override the model with GROQ_MODEL (default: llama-3.3-70b-versatile).
GROQ_API_KEY=

# ElementPay (stablecoin gateway) — admin-initiated order payments + webhook.
# Docs: https://devs.elementpay.net  ·  Console: https://console.elementpay.net
ELEMENTPAY_API_KEY=                 # server-side only
ELEMENTPAY_WEBHOOK_SECRET=          # verifies POST /api/webhooks/elementpay signatures
ELEMENTPAY_BASE_URL=https://sandbox.elementpay.net/api/v1   # prod: https://api.elementpay.net/api/v1
ELEMENTPAY_WALLET_ADDRESS=          # admin USDC wallet that receives on-ramped funds
ELEMENTPAY_TOKEN=                   # token contract address (e.g. USDC)
ELEMENTPAY_CURRENCY=KES
